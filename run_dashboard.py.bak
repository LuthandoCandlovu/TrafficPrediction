from fastapi import FastAPI
import uvicorn
import pandas as pd
import numpy as np
from pydantic import BaseModel
import joblib
import torch
from train_lstm import TrafficLSTM

app = FastAPI(title="Traffic Prediction API")

# Load models at startup
xgboost_model = joblib.load('xgboost_model.pkl')
# IMPORTANT: input_dim must match the number of features used during training (6)
lstm_model = TrafficLSTM(input_dim=6, hidden_dim=64, num_layers=2, output_dim=1)
lstm_model.load_state_dict(torch.load('lstm_model.pth'))
lstm_model.eval()
lstm_scaler = joblib.load('lstm_scaler.pkl')

class PredictionRequest(BaseModel):
    features: dict   # a dictionary with the required feature names

@app.get("/")
def root():
    return {"message": "Traffic Prediction API is running"}

@app.post("/predict/xgboost")
def predict_xgboost(req: PredictionRequest):
    # Convert incoming dict to DataFrame row
    df = pd.DataFrame([req.features])
    # Ensure columns order matches training
    feature_cols = ['hour', 'day_of_week', 'weather_temp', 'weather_precip',
                    'volume', 'speed_lag_1', 'speed_lag_2', 'speed_lag_3',
                    'rolling_mean_3']
    X = df[feature_cols].values
    pred = xgboost_model.predict(X)[0]
    return {"predicted_speed": pred}

@app.post("/predict/lstm")
def predict_lstm(req: PredictionRequest):
    # Expects a list of 6 rows in features
    df = pd.DataFrame(req.features)
    # Ensure columns: hour, day_of_week, weather_temp, weather_precip, volume, speed
    seq = df[['hour', 'day_of_week', 'weather_temp', 'weather_precip', 'volume', 'speed']].values
    X_scaled = lstm_scaler.transform(seq)
    X_tensor = torch.tensor(X_scaled, dtype=torch.float32).unsqueeze(0)
    with torch.no_grad():
        pred = lstm_model(X_tensor).item()
    return {"predicted_speed": pred}

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
